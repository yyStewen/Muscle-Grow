<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="com.musclegrow.mapper.SupplementMapper">

    <select id="pageQuery" resultType="com.musclegrow.vo.SupplementVO">
        select s.*, c.name as categoryName
        from supplement s
        left join category c on s.category_id = c.id
        <where>
            <if test="dto.name != null and dto.name != ''">
                and s.name like concat('%', #{dto.name}, '%')
            </if>
            <if test="dto.categoryId != null">
                and s.category_id = #{dto.categoryId}
            </if>
            <if test="dto.status != null">
                and s.status = #{dto.status}
            </if>
        </where>
        order by s.update_time desc
    </select>

</mapper>
